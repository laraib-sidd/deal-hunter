# Deal Hunter — Server Environment
# Copy to .env and fill in values

# Groq (free, https://console.groq.com)
DEAL_HUNTER_GROQ_API_KEY=

# Reddit (https://reddit.com/prefs/apps)
DEAL_HUNTER_REDDIT_CLIENT_ID=
DEAL_HUNTER_REDDIT_CLIENT_SECRET=

# Telegram alerts
DEAL_HUNTER_TELEGRAM__ENABLED=true
DEAL_HUNTER_TELEGRAM__BOT_TOKEN=
DEAL_HUNTER_TELEGRAM__CHAT_ID=

# SQLite path (mounted volume)
DEAL_HUNTER_DB_PATH=/data/deals.db
